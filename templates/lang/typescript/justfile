# Run the project
run:
    bun run src/index.ts

# Run with auto-reload (logs to dev.log for agent visibility)
dev:
    bun --hot src/index.ts 2>&1 | tee dev.log

# Run tests
test:
    bun test

# Run tests continuously (on file change)
test-watch:
    fd -e ts | entr -cn bun test

# Add a dependency
add *packages:
    bun add {{packages}}
