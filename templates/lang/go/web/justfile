set shell := ["bash", "-eo", "pipefail", "-c"]

# Generate templ files
generate:
    templ generate

# Run the project
run: generate
    go run .

# Run with auto-reload and browser live reload (logs to dev.log for agent visibility)
dev:
    APP_PORT=$((${PORT:-4000} + 1)) air -proxy.enabled true -proxy.proxy_port ${PORT:-4000} -proxy.app_port $((${PORT:-4000} + 1)) 2>&1 | tee dev.log

# Run tests
test:
    go test ./...

# Run tests continuously (on file change)
test-watch:
    fd -e go -e templ | entr -cn go test ./...

# Add a dependency
add *packages:
    go get {{packages}}

# Open in browser
browse:
    #!/bin/sh
    u="http://${DEV_HOST:-localhost}:${PORT:-4000}"
    if [ -n "$WAYLAND_DISPLAY" ]; then
        chromium --ozone-platform=wayland "$u" >/dev/null 2>&1 &
        echo "Opened browser: $u"
    else
        printf '\e]52;c;%s\a' "$(printf '%s' "$u" | base64)" > /dev/tty
        echo "Copied to clipboard: $u"
    fi
