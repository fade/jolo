# Run the project
run:
    uv run python src/{{MODULE_NAME}}/main.py

# Run with auto-reload (logs to dev.log for agent visibility)
dev:
    fd -e py | entr -rn uv run python src/{{MODULE_NAME}}/main.py 2>&1 | tee dev.log

# Run tests
test:
    uv run pytest

# Run tests continuously (on file change)
test-watch:
    fd -e py | entr -cn uv run pytest

# Add a dependency
add *packages:
    uv add {{packages}}

# Open in browser
browse:
    @u="http://${DEV_HOST:-localhost}:${PORT:-4000}"; printf '\e]52;c;%s\a' "$(printf '%s' "$u" | base64)" > /dev/tty ; echo "Copied to clipboard: $u"
