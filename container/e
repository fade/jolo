#!/bin/sh
# Smart Emacs launcher - connects to daemon via emacsclient
# Starts daemon automatically if not running (--alternate-editor="")

if [ -n "$WAYLAND_DISPLAY" ] || { [ -n "$DISPLAY" ] && xset q >/dev/null 2>&1; }; then
    emacsclient -c --alternate-editor="" "$@"
else
    emacsclient -nw --alternate-editor="" "$@"
fi
